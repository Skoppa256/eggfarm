// EggFarm IMS — Prisma schema
// Slice 1: warehouse ledger + stock projection (the foundation for rules 5.1/5.2/5.4).
// See CLAUDE.md §5 and docs/SRS.md §7 for the always-true rules behind this model.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Egg grade by Size & Health — stockable grades only (CLAUDE.md §6).
/// KOSONG (empty shells) is tracking-only and intentionally NOT here: it never
/// enters grading or stock.
enum SizeHealthGrade {
  ANGKAT_RAK
  A_PLUS_PLUS
  A_PLUS
  A
  B
  C
  KECIL
  MINI
  RETAK
  PLASTIK
  LUNAK
}

/// Kind of ledger movement (CLAUDE.md §5.1). Append-only; never updated/deleted.
enum MovementType {
  IN
  OUT
  CORRECTION
  VOID
}

/// What originated a movement. The specific sources (Angkat Rak, Grading, Sales,
/// Correction) arrive in later slices; ADJUSTMENT is the generic/manual source
/// used by the Slice 1 foundation actions.
enum SourceType {
  ANGKAT_RAK
  GRADING
  SALES
  CORRECTION
  ADJUSTMENT
}

/// Soft-delete status for master/catalog rows (CLAUDE.md §6 "Soft-delete only").
enum RecordStatus {
  ACTIVE
  INACTIVE
}

/// The three roles, enforced server-side (CLAUDE.md §6 / rule 5.5).
/// OWNER is read-only and must be rejected on every write path.
enum Role {
  SUPERADMIN
  ADMIN
  OWNER
}

/// Grading lifecycle. A DRAFT posts no stock; SUBMITTED has posted every line to
/// the ledger and locks the batch (CLAUDE.md §6, SRS FR-19).
enum GradingStatus {
  DRAFT
  SUBMITTED
}

/// Sales transaction lifecycle. A VOIDED transaction has had its stock restored via
/// compensating VOID movements and is excluded from sales reports by default (FR-33).
enum SalesStatus {
  ACTIVE
  VOIDED
}

/// Flock lifecycle. A flock ends once all its placements have ended (SRS §3.9).
enum FlockStatus {
  ACTIVE
  ENDED
}

/// Placement lifecycle. Ending a placement (fully culled/sold) frees its kandang.
enum PlacementStatus {
  ACTIVE
  ENDED
}

/// Feed-ingredient category (SRS FR-80). Also fixes the JENIS render order:
/// KONSENTRAT, then PREMIX, then GRAIN (jagung), then BRAN (dedak).
enum IngredientCategory {
  KONSENTRAT // Konsentrat / Finished Feed
  PREMIX // Premix / Supplement
  GRAIN // Grain / Jagung
  BRAN // Bran / Dedak
}

/// What originated an ingredient-stock movement (mirror of egg SourceType).
enum IngredientSourceType {
  DELIVERY // Admin feed delivery — stock IN
  MIXING // recipe draw-down on mixing confirm — stock OUT
  CORRECTION // reserved for a future supervised ingredient correction
}

/// A mixing recipe line: a main feed by % of the fresh mix, or a fixed-weight
/// supplement/premix that is not scaled by netting (SRS FR-84).
enum MixLineKind {
  MAIN_PERCENT
  FIXED_WEIGHT
}

/// OVK item category (SRS FR-91). Chemicals have no daily-record field.
enum OvkCategory {
  OBAT
  VITAMIN
  CHEMICAL
}

/// What originated an OVK office-stock movement (mirror of the ingredient ledger).
enum OvkSourceType {
  DELIVERY // Admin delivery to the office — stock IN
  TRANSFER // office → kandang transfer — stock OUT (the stock-reduction event)
  CORRECTION // supervised office-stock correction
}

// ---------------------------------------------------------------------------
// Master data
// ---------------------------------------------------------------------------

/// Grade by Type (Normal, Omega, ...). A table, extensible by Superadmin.
/// One half of the Egg SKU composite (sizeHealthGrade + typeGradeId).
model GradeType {
  id        String       @id @default(cuid())
  name      String       @unique
  status    RecordStatus @default(ACTIVE)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  warehouseStocks    WarehouseStock[]
  stockMovements     StockMovement[]
  angkatRakLifts     AngkatRakLift[]
  gradingLineItems   GradingLineItem[]
  lowStockThresholds LowStockThreshold[]
  salesLineItems     SalesLineItem[]
}

/// A storage location for graded egg stock. Minimal in Slice 1; low-stock
/// thresholds and farmhouse mapping arrive in later slices.
model Warehouse {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  warehouseStocks    WarehouseStock[]
  stockMovements     StockMovement[]
  farmhouseMappings  FarmhouseWarehouseMapping[]
  lowStockThresholds LowStockThreshold[]
  salesTransactions  SalesTransaction[]
}

// ---------------------------------------------------------------------------
// Ledger + projection (rules 5.1, 5.2, 5.4)
// ---------------------------------------------------------------------------

/// Balance cache: current quantity (pcs) per Egg SKU per warehouse.
/// DERIVED from the ledger and written ONLY by src/lib/server/ledger.ts (rule 5.4).
/// If this ever disagrees with the folded ledger, the ledger wins (rule 5.1).
model WarehouseStock {
  id              String          @id @default(cuid())
  warehouseId     String
  sizeHealthGrade SizeHealthGrade
  typeGradeId     String
  currentQuantity Int             @default(0) // pcs; never negative
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  gradeType GradeType @relation(fields: [typeGradeId], references: [id])

  @@unique([warehouseId, sizeHealthGrade, typeGradeId])
  @@index([warehouseId])
}

/// Append-only ledger of every stock change (rule 5.1). NEVER UPDATE or DELETE a
/// row — corrections/voids are new compensating rows. Written ONLY by
/// src/lib/server/ledger.ts (rule 5.4). preQuantity/postQuantity snapshot the
/// balance around this movement so the ledger is self-describing and auditable.
model StockMovement {
  id                String          @id @default(cuid())
  warehouseId       String
  sizeHealthGrade   SizeHealthGrade
  typeGradeId       String
  movementType      MovementType
  quantity          Int // magnitude in pcs (> 0); direction implied by movementType
  unitUsed          String          @default("PCS") // how the operator entered it (audit only)
  sourceType        SourceType
  sourceReferenceId String? // id of the originating record (collection/grading/sale/...)
  reason            String? // required (>= 20 chars) for CORRECTION; enforced at that entry point
  preQuantity       Int // balance before this movement
  postQuantity      Int // balance after this movement (== WarehouseStock.currentQuantity)
  date              DateTime        @default(now()) // business date of the movement
  enteredById       String // who entered it (the authenticated user)
  createdAt         DateTime        @default(now()) // immutable audit timestamp

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  gradeType GradeType @relation(fields: [typeGradeId], references: [id])
  enteredBy User      @relation(fields: [enteredById], references: [id])

  @@index([warehouseId, date])
  @@index([warehouseId, sizeHealthGrade, typeGradeId])
  @@index([enteredById])
}

// ---------------------------------------------------------------------------
// Auth & users (Slice 2)
// ---------------------------------------------------------------------------

/// An application user. Superadmin provisions all users; no self-signup.
/// Deactivation (status = INACTIVE) locks the user out immediately because every
/// request re-checks status via the DB-backed session.
model User {
  id           String       @id @default(cuid())
  name         String
  username     String       @unique
  passwordHash String
  role         Role
  status       RecordStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sessions          Session[]
  stockMovements    StockMovement[]
  mappingChanges    FarmhouseWarehouseMapping[]
  batchChanges      FarmhouseBatchSetting[]
  collectionRecords CollectionRecord[]
  gradingRecords    GradingRecord[]
  salesTransactions SalesTransaction[] @relation("SalesEnteredBy")
  voidedSales         SalesTransaction[] @relation("SalesVoidedBy")
  createdFlocks       Flock[]
  dailyRecords        DailyRecord[]
  ingredientMovements IngredientMovement[]
  mixingRecords       MixingRecord[]
  ovkMovements        OvkMovement[]
}

/// Server-side session row. A signed httpOnly cookie (jose) carries only the
/// session id; the row is the source of truth, so deleting it (logout, deactivate)
/// invalidates the cookie immediately.
model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Config & master data (Slice 3)
// ---------------------------------------------------------------------------

/// A farmhouse (kandang). Admin-managed operational structure. Its warehouse
/// assignment and max-batches-per-day are NOT mutable columns — both are
/// effective-dated logs (below) so history is preserved and changes take effect on
/// a specific date (SRS FR-41).
model Farmhouse {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  warehouseMappings FarmhouseWarehouseMapping[]
  batchSettings     FarmhouseBatchSetting[]
  collectionRecords CollectionRecord[]
  gradingRecords    GradingRecord[]
  placements        Placement[]
  dailyRecords      DailyRecord[]
  mixingRecords     MixingRecord[]
  ovkMovements      OvkMovement[]
}

/// Effective-dated farmhouse→warehouse mapping (SRS §7 "Mapping Log"). Append-only:
/// a change adds a new row. The assignment in force on date D is the row with the
/// greatest effectiveFrom <= D (ties broken by createdAt). History is retained, so
/// past entries stay linked to the warehouse they were dispatched to.
model FarmhouseWarehouseMapping {
  id            String   @id @default(cuid())
  farmhouseId   String
  warehouseId   String
  effectiveFrom DateTime @db.Date
  changedById   String
  createdAt     DateTime @default(now())

  farmhouse Farmhouse @relation(fields: [farmhouseId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  changedBy User      @relation(fields: [changedById], references: [id])

  @@index([farmhouseId, effectiveFrom])
}

/// Effective-dated max-batches-per-day per farmhouse. A change made on day D is
/// stored with effectiveFrom = D+1, so it "takes effect the next day" (SRS FR-41);
/// a newly created farmhouse's first setting is effective the same day. The value
/// in force on date D is the row with the greatest effectiveFrom <= D.
model FarmhouseBatchSetting {
  id               String   @id @default(cuid())
  farmhouseId      String
  maxBatchesPerDay Int
  effectiveFrom    DateTime @db.Date
  changedById      String
  createdAt        DateTime @default(now())

  farmhouse Farmhouse @relation(fields: [farmhouseId], references: [id])
  changedBy User      @relation(fields: [changedById], references: [id])

  @@index([farmhouseId, effectiveFrom])
}

/// Measurement unit catalog (Superadmin-managed). `pcsEquivalent` expresses each
/// unit in pieces (Rak = 30, Pcs = 1), CLAUDE.md §6.
model MeasurementUnit {
  id            String       @id @default(cuid())
  name          String       @unique
  pcsEquivalent Int
  status        RecordStatus @default(ACTIVE)
  sortOrder     Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

// ---------------------------------------------------------------------------
// Collection input (Slice 4)
// ---------------------------------------------------------------------------

/// One batch's raw egg count for a kandang on a business date (SRS §3.2).
/// Type-agnostic counts (pcs); Angkat Rak is split by Type in AngkatRakLift.
/// Only Angkat Rak posts to stock (via ledger.ts); the counts feed grading (Slice 5).
/// `maxBatchesAtEntry` is the effective max-batches snapshot, frozen at entry
/// (write-once, CLAUDE.md §5.3).
model CollectionRecord {
  id                String   @id @default(cuid())
  farmhouseId       String
  date              DateTime @db.Date // business date (WITA)
  batchNumber       Int
  goodEggs          Int      @default(0) // pcs, Type-agnostic
  telurRetak        Int      @default(0) // pcs
  telurLunak        Int      @default(0) // pcs
  telurKosong       Int      @default(0) // pcs (tracking only; never stocked)
  remarks           String?
  maxBatchesAtEntry Int // frozen snapshot of the kandang's effective max batches
  enteredById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  farmhouse      Farmhouse       @relation(fields: [farmhouseId], references: [id])
  enteredBy      User            @relation(fields: [enteredById], references: [id])
  angkatRakLifts AngkatRakLift[]
  gradingRecords GradingRecord[]

  @@unique([farmhouseId, date, batchNumber]) // duplicate prevention (SRS FR-09)
  @@index([farmhouseId, date])
}

/// One Angkat Rak lift within a collection, for a single Grade by Type. Quantity in
/// pcs. On collection save each lift posts an IN movement to the kandang's warehouse
/// as SKU (ANGKAT_RAK, typeGrade) — via ledger.ts only (rule 5.4).
model AngkatRakLift {
  id                 String @id @default(cuid())
  collectionRecordId String
  typeGradeId        String
  quantity           Int // pcs

  collectionRecord CollectionRecord @relation(fields: [collectionRecordId], references: [id], onDelete: Cascade)
  gradeType        GradeType        @relation(fields: [typeGradeId], references: [id])

  @@unique([collectionRecordId, typeGradeId]) // one row per Type per collection
}

// ---------------------------------------------------------------------------
// Grading (Slice 5)
// ---------------------------------------------------------------------------

/// One batch's grading session (SRS §3.3). A DRAFT holds line items but posts no
/// stock; on SUBMIT every line posts to the ledger as its Egg SKU IN and the batch
/// is locked. Grading is batch-sequential: batch N requires N-1 submitted.
model GradingRecord {
  id                 String        @id @default(cuid())
  farmhouseId        String
  date               DateTime      @db.Date // business date (WITA)
  batchNumber        Int
  status             GradingStatus @default(DRAFT)
  linkedCollectionId String?
  remarks            String?
  enteredById        String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  farmhouse        Farmhouse         @relation(fields: [farmhouseId], references: [id])
  enteredBy        User              @relation(fields: [enteredById], references: [id])
  linkedCollection CollectionRecord? @relation(fields: [linkedCollectionId], references: [id])
  lineItems        GradingLineItem[]

  @@unique([farmhouseId, date, batchNumber])
  @@index([farmhouseId, date])
}

/// One graded lot = Egg SKU (Size & Health grade × Type), quantity in pcs. On
/// submit, posts to stock via ledger.ts only (rule 5.4). ANGKAT_RAK is never a
/// grading line (it bypasses grading); KOSONG is not a stockable grade at all.
model GradingLineItem {
  id              String          @id @default(cuid())
  gradingRecordId String
  sizeHealthGrade SizeHealthGrade
  typeGradeId     String
  quantity        Int // pcs

  gradingRecord GradingRecord @relation(fields: [gradingRecordId], references: [id], onDelete: Cascade)
  gradeType     GradeType     @relation(fields: [typeGradeId], references: [id])

  @@unique([gradingRecordId, sizeHealthGrade, typeGradeId]) // one row per Egg SKU
}

// ---------------------------------------------------------------------------
// Low-stock thresholds (Slice 6)
// ---------------------------------------------------------------------------

/// Configurable minimum balance (pcs) per Egg SKU per warehouse (SRS FR-27). A SKU
/// is "low" when its WarehouseStock.currentQuantity < minQuantity. This is config —
/// a SEPARATE table from WarehouseStock, so it never violates rule 5.4 (only
/// ledger.ts writes WarehouseStock). Admin-managed.
model LowStockThreshold {
  id              String          @id @default(cuid())
  warehouseId     String
  sizeHealthGrade SizeHealthGrade
  typeGradeId     String
  minQuantity     Int // pcs
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  gradeType GradeType @relation(fields: [typeGradeId], references: [id])

  @@unique([warehouseId, sizeHealthGrade, typeGradeId])
  @@index([warehouseId])
}

// ---------------------------------------------------------------------------
// Buyers + Sales & Dispatch (Slice 7)
// ---------------------------------------------------------------------------

/// A pre-registered buyer. Soft-delete via status: a deactivated buyer is excluded
/// from new transactions but retained in history (SRS FR-36..38).
model Buyer {
  id        String       @id @default(cuid())
  name      String
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  salesTransactions SalesTransaction[]
}

/// A sales/dispatch transaction: one warehouse, one buyer, one business date, many
/// line items. On submit every line deducts stock atomically (OUT via ledger.ts,
/// rule 5.4). Voiding restores stock via compensating VOID movements (never deletes)
/// and flips status to VOIDED (SRS §3.5).
model SalesTransaction {
  id          String      @id @default(cuid())
  date        DateTime    @db.Date // business date (WITA)
  warehouseId String
  buyerId     String
  status      SalesStatus @default(ACTIVE)
  notes       String?
  voidReason  String?
  voidedById  String?
  voidedAt    DateTime?
  enteredById String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  buyer     Buyer           @relation(fields: [buyerId], references: [id])
  enteredBy User            @relation("SalesEnteredBy", fields: [enteredById], references: [id])
  voidedBy  User?           @relation("SalesVoidedBy", fields: [voidedById], references: [id])
  lineItems SalesLineItem[]

  @@index([warehouseId, date])
  @@index([buyerId, date])
}

/// One line of a sales transaction = an Egg SKU (Size&Health × Type), quantity in
/// pcs. `unitUsed` records how the operator entered it (RAK or PCS). Each line posts
/// its own OUT movement on submit (FR-31).
model SalesLineItem {
  id              String          @id @default(cuid())
  transactionId   String
  sizeHealthGrade SizeHealthGrade
  typeGradeId     String
  quantity        Int // pcs
  unitUsed        String

  transaction SalesTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  gradeType   GradeType        @relation(fields: [typeGradeId], references: [id])

  @@index([transactionId])
}

// ---------------------------------------------------------------------------
// Flock & placement lifecycle (Slice 8)
// ---------------------------------------------------------------------------

/// One chick-in delivery: shared strain, chick-in date, and placement age (days at
/// chick-in). May populate one or more kandang as separate placements (SRS §3.9).
/// Created by Superadmin only.
model Flock {
  id           String      @id @default(cuid())
  strain       String
  chickInDate  DateTime    @db.Date // business date (WITA)
  placementAge Int // days at chick-in (shared across the flock)
  status       FlockStatus @default(ACTIVE)
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  createdBy  User        @relation(fields: [createdById], references: [id])
  placements Placement[]
}

/// A flock's portion in one kandang, with its own Populasi Awal and its own daily
/// HIDUP ledger. One ACTIVE placement per kandang at a time (enforced in the service).
/// Ending it (endDate set) frees the kandang; history is retained.
model Placement {
  id          String          @id @default(cuid())
  flockId     String
  farmhouseId String
  populasiAwal Int // initial hen count (per placement)
  startDate   DateTime        @db.Date // = flock chick-in date
  endDate     DateTime?       @db.Date
  status      PlacementStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  flock          Flock            @relation(fields: [flockId], references: [id])
  farmhouse      Farmhouse        @relation(fields: [farmhouseId], references: [id])
  hidupSnapshots HidupSnapshot[]
  dailyRecords   DailyRecord[]
  mixingRecords  MixingRecord[]

  @@index([farmhouseId, status])
  @@index([flockId])
}

/// Running live-hen count (HIDUP) snapshot for a placement on a business date =
/// previous HIDUP − that day's MATI − AFKIR (SRS §3.9). Seeded at chick-in with
/// hidup = Populasi Awal. Write-once per (placement, date) — the running value is
/// persisted, not recomputed from birth (CLAUDE.md §5.3). MATI/AFKIR entry via the
/// daily record is Slice 9; this is the model + helper it builds on.
model HidupSnapshot {
  id          String   @id @default(cuid())
  placementId String
  date        DateTime @db.Date
  mati        Int      @default(0)
  afkir       Int      @default(0)
  hidup       Int
  createdAt   DateTime @default(now())

  placement Placement @relation(fields: [placementId], references: [id], onDelete: Cascade)

  @@unique([placementId, date])
  @@index([placementId, date])
}

// ---------------------------------------------------------------------------
// Daily farmhouse recording (Slice 9)
// ---------------------------------------------------------------------------

/// One record per kandang per business day for the active placement (SRS §3.10,
/// FR-67). Admin types only a handful of yellow fields; the rest is derived. The
/// stateful derived values are frozen write-once (§5.3): `hidup` (the day's running
/// HIDUP, mirrored from HidupSnapshot) and `hdPercent`. The egg buckets are NOT
/// stored — they derive live from collection (and reconcile to grading). The PAKAN
/// block is frozen write-once once PAKAN MASUK is known (Slice 10 mixing): at record
/// creation if the mix already exists, else when the mix is confirmed. Null until then.
model DailyRecord {
  id            String   @id @default(cuid())
  farmhouseId   String
  placementId   String
  date          DateTime @db.Date // business date (WITA)

  // Admin inputs (the "yellow fields"). Feed quantities are kg (Decimal, never float).
  mati          Int      @default(0)
  afkir         Int      @default(0)
  sisaDigunakan Decimal  @default(0) @db.Decimal(10, 3) // reusable leftover; carries to next day's TERSEDIA
  sisaDibuang   Decimal  @default(0) @db.Decimal(10, 3) // discarded leftover
  beratTelur    Decimal  @default(0) @db.Decimal(10, 3) // daily egg mass (kg), global daily figure
  beratBadan    Decimal? @db.Decimal(10, 2) // sampled body weight (optional, weekly; record-only)
  obatNote      String? // administration note only — never moves OVK stock
  vitaminNote   String? // administration note only — never moves OVK stock
  keterangan    String?

  // Frozen derived, write-once at creation (§5.3).
  hidup     Int // running HIDUP for the day (from the HidupSnapshot ledger)
  hdPercent Decimal @db.Decimal(6, 2) // (Utuh+Lunak+Pecah+Kosong) / HIDUP * 100

  // PAKAN block (Slice 10) — posted from the mixing event, frozen write-once (§5.3).
  // Null until PAKAN MASUK is known (mixing done for the day); once set, never rewritten.
  pakanMasuk         Decimal? @db.Decimal(12, 3) // = mixing TOTAL CAMPUR (fresh mix, kg)
  reusableLeftoverIn Decimal? @db.Decimal(12, 3) // yesterday's SISA DIGUNAKAN at freeze time
  pakanTersedia      Decimal? @db.Decimal(12, 3) // = MASUK + reusableLeftoverIn
  realisasiIntake    Decimal? @db.Decimal(12, 3) // = TERSEDIA − (DIGUNAKAN + DIBUANG)
  gramPerEkor        Decimal? @db.Decimal(10, 2) // = INTAKE / HIDUP × 1000
  fcr                Decimal? @db.Decimal(10, 3) // = INTAKE / BERAT TELUR
  jenis              String? // derived feed recipe string (JENIS)

  enteredById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmhouse Farmhouse @relation(fields: [farmhouseId], references: [id])
  placement Placement @relation(fields: [placementId], references: [id])
  enteredBy User      @relation(fields: [enteredById], references: [id])

  @@unique([farmhouseId, date]) // one record per kandang per business day (FR-67)
  @@index([placementId, date])
  @@index([farmhouseId, date])
}

// ---------------------------------------------------------------------------
// PAKAN — feed ingredients, central stock ledger, and mixing (Slice 10)
// ---------------------------------------------------------------------------

/// A raw feed ingredient in the central store (SRS FR-80). Superadmin-managed master
/// data. `baseUnit` is the stock unit (kg); optional unit conversions (e.g. karung→kg)
/// are handled at entry, not stored here for v2.
model Ingredient {
  id        String             @id @default(cuid())
  name      String             @unique
  category  IngredientCategory
  baseUnit  String             @default("kg")
  status    RecordStatus       @default(ACTIVE)
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  stock     IngredientStock?
  movements IngredientMovement[]
  mixLines  MixingLine[]
}

/// Balance cache: current central quantity (kg) per ingredient. DERIVED from the
/// IngredientMovement ledger and written ONLY by src/lib/server/ingredientLedger.ts
/// (rule 5.4 mirror). If it ever disagrees with the folded ledger, the ledger wins.
model IngredientStock {
  id              String   @id @default(cuid())
  ingredientId    String   @unique
  currentQuantity Decimal  @default(0) @db.Decimal(12, 3) // kg; never negative
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}

/// Append-only ledger of every central ingredient-stock change (mirror of the egg
/// StockMovement). NEVER updated/deleted; written ONLY by ingredientLedger.ts.
/// `quantity` is the positive magnitude (kg); direction is `movementType` (IN/OUT).
model IngredientMovement {
  id                String               @id @default(cuid())
  ingredientId      String
  movementType      MovementType // IN (delivery) / OUT (mixing draw-down)
  quantity          Decimal              @db.Decimal(12, 3) // magnitude kg (> 0)
  sourceType        IngredientSourceType
  sourceReferenceId String? // originating record (delivery / mixing) id
  reason            String?
  preQuantity       Decimal              @db.Decimal(12, 3)
  postQuantity      Decimal              @db.Decimal(12, 3)
  date              DateTime             @default(now()) // business date of the movement
  enteredById       String
  createdAt         DateTime             @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  enteredBy  User       @relation(fields: [enteredById], references: [id])

  @@index([ingredientId, date])
  @@index([enteredById])
}

/// One kandang's mixing event for a consumption day (SRS §3.11). Mixed the night
/// before, dated to the day eaten. The computed values are frozen write-once on
/// confirmation (§5.3): the requirement, the reusable-leftover snapshot, TOTAL CAMPUR
/// (= PAKAN MASUK), and the JENIS string. Confirming it draws each line's weight down
/// from central ingredient stock (via ingredientLedger.ts).
model MixingRecord {
  id               String   @id @default(cuid())
  farmhouseId      String
  placementId      String
  date             DateTime @db.Date // consumption day (WITA)
  projectedIntake  Decimal  @db.Decimal(10, 3) // g/bird (Admin input per kandang)
  hidupAtMix       Int // HIDUP snapshot used for the requirement
  requirement      Decimal  @db.Decimal(12, 3) // kg = HIDUP × intake / 1000
  reusableLeftover Decimal  @db.Decimal(12, 3) // kg = yesterday's SISA DIGUNAKAN
  totalCampur      Decimal  @db.Decimal(12, 3) // kg = max(0, requirement − leftover) = MASUK
  jenis            String // derived recipe string (JENIS)
  enteredById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  farmhouse Farmhouse    @relation(fields: [farmhouseId], references: [id])
  placement Placement    @relation(fields: [placementId], references: [id])
  enteredBy User         @relation(fields: [enteredById], references: [id])
  lines     MixingLine[]

  @@unique([farmhouseId, date]) // one mix per kandang per consumption day
  @@index([placementId, date])
}

/// One recipe line of a mixing event. A MAIN_PERCENT line's weight derives as
/// `percent × TOTAL CAMPUR`; a FIXED_WEIGHT (supplement/premix) line's weight is taken
/// as entered (not scaled). `computedWeight` is the frozen kg drawn from stock.
model MixingLine {
  id             String      @id @default(cuid())
  mixingRecordId String
  ingredientId   String
  kind           MixLineKind
  percent        Decimal?    @db.Decimal(6, 3) // MAIN_PERCENT: % of the fresh mix
  fixedWeight    Decimal?    @db.Decimal(12, 3) // FIXED_WEIGHT: kg as entered
  computedWeight Decimal     @db.Decimal(12, 3) // the frozen kg drawn from central stock

  mixingRecord MixingRecord @relation(fields: [mixingRecordId], references: [id], onDelete: Cascade)
  ingredient   Ingredient   @relation(fields: [ingredientId], references: [id])

  @@index([mixingRecordId])
}

// ---------------------------------------------------------------------------
// OVK — Obat / Vitamin / Chemical inventory (Slice 11)
// ---------------------------------------------------------------------------

/// An OVK item in the central office store (SRS FR-91). Superadmin-managed. `baseUnit`
/// is the stock unit; optional per-item `unitConversions` let entries use another unit
/// (botol, pcs, box…). Stock moves via ovkLedger.ts only (rule 5.4 mirror).
model OvkItem {
  id        String       @id @default(cuid())
  name      String       @unique
  category  OvkCategory
  baseUnit  String // e.g. liter, gram, botol, box
  status    RecordStatus @default(ACTIVE)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  stock           OvkStock?
  unitConversions OvkUnitConversion[]
  movements       OvkMovement[]
}

/// A per-item unit conversion: `1 unitName = factorToBase × baseUnit` (e.g. 1 botol =
/// 1 liter; 1 pcs = 100 gram). The base unit itself needs no row (factor 1).
model OvkUnitConversion {
  id           String  @id @default(cuid())
  ovkItemId    String
  unitName     String
  factorToBase Decimal @db.Decimal(14, 4)

  ovkItem OvkItem @relation(fields: [ovkItemId], references: [id], onDelete: Cascade)

  @@unique([ovkItemId, unitName])
}

/// Balance cache: current office quantity (base unit) per OVK item. DERIVED from the
/// OvkMovement ledger and written ONLY by src/lib/server/ovkLedger.ts (rule 5.4 mirror).
model OvkStock {
  id              String   @id @default(cuid())
  ovkItemId       String   @unique
  currentQuantity Decimal  @default(0) @db.Decimal(14, 3) // base unit; never negative
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ovkItem OvkItem @relation(fields: [ovkItemId], references: [id])
}

/// Append-only ledger of every office OVK-stock change (mirror of the ingredient ledger).
/// A DELIVERY is IN; a TRANSFER (office → kandang) is OUT and carries the kandang + an
/// optional note; a CORRECTION carries pre/post + a reason. `quantity` is the base-unit
/// magnitude; `enteredQuantity`/`unitUsed` record what was physically entered (for the
/// pemakaian report). NEVER updated/deleted; written ONLY by ovkLedger.ts.
model OvkMovement {
  id              String        @id @default(cuid())
  ovkItemId       String
  movementType    MovementType // IN (delivery) / OUT (transfer) / CORRECTION
  sourceType      OvkSourceType
  quantity        Decimal       @db.Decimal(14, 3) // base-unit magnitude (> 0)
  enteredQuantity Decimal       @db.Decimal(14, 3) // quantity as entered (in unitUsed)
  unitUsed        String // the unit the operator entered
  farmhouseId     String? // set for a TRANSFER (the receiving kandang)
  note            String? // optional transfer note
  reason          String? // required (>= 20) for CORRECTION
  preQuantity     Decimal       @db.Decimal(14, 3)
  postQuantity    Decimal       @db.Decimal(14, 3)
  date            DateTime      @default(now()) // business date of the movement
  enteredById     String
  createdAt       DateTime      @default(now())

  ovkItem   OvkItem    @relation(fields: [ovkItemId], references: [id])
  farmhouse Farmhouse? @relation(fields: [farmhouseId], references: [id])
  enteredBy User       @relation(fields: [enteredById], references: [id])

  @@index([ovkItemId, date])
  @@index([farmhouseId, date])
  @@index([enteredById])
}
